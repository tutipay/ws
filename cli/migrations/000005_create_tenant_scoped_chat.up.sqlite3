CREATE TABLE IF NOT EXISTS "chats_v2" (
	"tenant_id" TEXT NOT NULL,
	"id" TEXT NOT NULL,
	"from_user_id" INTEGER NOT NULL CHECK ("from_user_id" > 0),
	"to_user_id" INTEGER NOT NULL CHECK ("to_user_id" > 0),
	"text" TEXT NOT NULL,
	"is_delivered" INTEGER NOT NULL DEFAULT 0,
	"date" INTEGER NOT NULL,
	PRIMARY KEY ("tenant_id", "id")
);

CREATE INDEX IF NOT EXISTS "idx_chats_v2_unread"
	ON "chats_v2"("tenant_id", "to_user_id", "is_delivered", "date", "id");

CREATE TABLE IF NOT EXISTS "contacts_v2" (
	"tenant_id" TEXT NOT NULL,
	"owner_user_id" INTEGER NOT NULL CHECK ("owner_user_id" > 0),
	"contact_user_id" INTEGER NOT NULL CHECK ("contact_user_id" > 0),
	PRIMARY KEY ("tenant_id", "owner_user_id", "contact_user_id")
);

CREATE INDEX IF NOT EXISTS "idx_contacts_v2_reverse"
	ON "contacts_v2"("tenant_id", "contact_user_id", "owner_user_id");
